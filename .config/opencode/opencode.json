        },
        "gpt-5-nano": {
          "name": "GPT 5 Nano"
        }
      }
    },
    "google": {
      "name": "Google",
      "models": {
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        }
