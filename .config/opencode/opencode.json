{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
	"opencode-pty",
	  //"oh-my-opencode@latest"
  ],
  "provider": {
    "openai": {
      "name": "OpenAI",
      "models": {
	"gpt-5.4": {
	  "name": "GPT 5.4"
	},
        "gpt-5.2": {
          "name": "GPT 5.2"
        },
        "gpt-5.2-codex": {
